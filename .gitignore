# --- Berkas hasil runtime simulasi ---
# Log terstruktur per entitas (log_as.jsonl, log_n1.jsonl, dst.)
log_*.jsonl
# Berkas sadapan yang ditulis N1 & dibaca penyerang
capture.bin

# --- ProVerif ---
# Output hasil verifikasi yang disimpan ke berkas
hasil_verifikasi.txt
*.out

# ==========================================================================
# Python
# ==========================================================================
# Byte-compiled / optimized / cache
__pycache__/
*.py[cod]
*$py.class

# Distribution / packaging
.Python
build/
dist/
*.egg-info/
.eggs/

# Virtual environments
.venv/
venv/
env/
ENV/

# Unit test / coverage
.pytest_cache/
.coverage
htmlcov/

# ==========================================================================
# Editor / IDE
# ==========================================================================
.vscode/
.idea/
*.swp
*.swo

# ==========================================================================
# Sistem Operasi
# ==========================================================================
.DS_Store
Thumbs.db
